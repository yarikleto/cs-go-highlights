[
  {
    "id": "extract",
    "name": "Extract Demos",
    "description": "Recursively extract .dem files from an archive (zip/rar) into a flat folder",
    "category": "Utility",
    "options": [
      {
        "name": "archive",
        "label": "Archive File",
        "type": "file",
        "filters": {
          "name": "Archive",
          "extensions": [
            "zip",
            "rar"
          ]
        },
        "required": true,
        "description": "Path to archive containing demo files"
      },
      {
        "name": "output",
        "label": "Output Folder",
        "type": "folder",
        "default": "./demos",
        "description": "Folder where .dem files will be placed (flat structure)"
      }
    ]
  },
  {
    "id": "analyze-v2",
    "name": "Analyze V2",
    "description": "Parse demo files and detect highlights (no points, with extended metadata)",
    "category": "Pipeline",
    "options": [
      {
        "name": "demos",
        "label": "Demos Folder",
        "type": "folder",
        "required": true,
        "default": "./demos",
        "description": "Path to folder containing .dem files"
      },
      {
        "name": "output",
        "label": "Output Folder",
        "type": "folder",
        "default": "./output",
        "description": "Output folder for highlights.json"
      },
      {
        "name": "solo-kills-file",
        "label": "Solo Kills File",
        "type": "file",
        "filters": {
          "name": "JSON",
          "extensions": [
            "json"
          ]
        },
        "description": "Optional JSON file with manual solo kill ticks"
      }
    ]
  },
  {
    "id": "analyze-postprocess-ui",
    "name": "Analyze Postprocess UI",
    "description": "Calculate playback boundaries, speedup segments, and slowmo triggers",
    "category": "Pipeline",
    "options": [
      {
        "name": "highlights",
        "label": "Highlights File",
        "type": "file",
        "filters": {
          "name": "JSON",
          "extensions": [
            "json"
          ]
        },
        "default": "./output/highlights.json",
        "description": "Path to highlights.json from analyze-v2"
      },
      {
        "name": "output",
        "label": "Output File",
        "type": "text",
        "default": "./output/highlights_postprocess.json",
        "description": "Output file path"
      }
    ]
  },
  {
    "id": "analyze",
    "name": "Analyze (Legacy)",
    "description": "Original analyzer with points calculation and music mapping",
    "category": "Pipeline",
    "options": [
      {
        "name": "demos",
        "label": "Demos Folder",
        "type": "folder",
        "required": true,
        "default": "./demos"
      },
      {
        "name": "output",
        "label": "Output Folder",
        "type": "folder",
        "default": "./output"
      },
      {
        "name": "reset-music",
        "label": "Reset Music Mapping",
        "type": "boolean",
        "default": false,
        "description": "Discard existing music offsets"
      },
      {
        "name": "solo-kills-file",
        "label": "Solo Kills File",
        "type": "file",
        "filters": {
          "name": "JSON",
          "extensions": [
            "json"
          ]
        }
      }
    ]
  },
  {
    "id": "record",
    "name": "Record",
    "description": "Record highlights using HLAE (produces raw video clips)",
    "category": "Pipeline",
    "options": [
      {
        "name": "highlights",
        "label": "Highlights File",
        "type": "file",
        "filters": {
          "name": "JSON",
          "extensions": [
            "json"
          ]
        },
        "default": "./output/highlights.json"
      },
      {
        "name": "demos",
        "label": "Demos Folder",
        "type": "folder",
        "default": "./demos"
      },
      {
        "name": "hlae",
        "label": "HLAE Path",
        "type": "file",
        "filters": {
          "name": "Executable",
          "extensions": [
            "exe"
          ]
        },
        "default": "C:\\Program Files (x86)\\HLAE\\hlae.exe"
      },
      {
        "name": "csgo",
        "label": "CS:GO Folder",
        "type": "folder",
        "default": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\Counter-Strike Global Offensive"
      },
      {
        "name": "output",
        "label": "Output Folder",
        "type": "folder",
        "default": "./output"
      },
      {
        "name": "quality",
        "label": "Quality Preset",
        "type": "select",
        "choices": [
          {
            "value": "high",
            "label": "High (slow)"
          },
          {
            "value": "medium",
            "label": "Medium (balanced)"
          },
          {
            "value": "fast",
            "label": "Fast"
          },
          {
            "value": "draft",
            "label": "Draft (preview)"
          }
        ],
        "default": "medium"
      },
      {
        "name": "player",
        "label": "Filter by Player (Steam ID)",
        "type": "text",
        "description": "Only record highlights for this player"
      },
      {
        "name": "id",
        "label": "Highlight ID",
        "type": "text",
        "description": "Record only this specific highlight"
      },
      {
        "name": "voice-chat",
        "label": "Record with HUD, chat, voice",
        "type": "boolean",
        "default": false,
        "excludes": [
          "voice"
        ]
      },
      {
        "name": "voice",
        "label": "Record with voice (no HUD)",
        "type": "boolean",
        "default": false,
        "description": "Double-pass: record voice audio separately, then clean video without HUD",
        "excludes": [
          "voice-chat"
        ]
      },
      {
        "name": "keep-voice",
        "label": "Keep voice file separately",
        "type": "boolean",
        "default": false,
        "description": "Save voice audio as a separate file next to the clip (e.g. clip_voice.mp4)",
        "requiresOption": "voice"
      },
      {
        "name": "force",
        "label": "Force Re-record",
        "type": "boolean",
        "default": false,
        "description": "Overwrite existing clips instead of skipping them"
      }
    ]
  },
  {
    "id": "postprocess-ui",
    "name": "Postprocess UI",
    "description": "Apply visual effects to recorded clips (slowmo, speedup, overlay)",
    "category": "Pipeline",
    "options": [
      {
        "name": "highlights",
        "label": "Highlights File",
        "type": "file",
        "filters": {
          "name": "JSON",
          "extensions": [
            "json"
          ]
        },
        "default": "./output/highlights.json"
      },
      {
        "name": "clips",
        "label": "Clips Folder",
        "type": "folder",
        "default": "./output/clips"
      },
      {
        "name": "output",
        "label": "Output Folder",
        "type": "folder",
        "default": "./output/clips_processed"
      },
      {
        "name": "speedup",
        "label": "Speedup Multiplier",
        "type": "number",
        "default": 3,
        "min": 1,
        "max": 10
      },
      {
        "name": "slowmo",
        "label": "Slowmo Factor",
        "type": "number",
        "default": 0.6,
        "min": 0.1,
        "max": 1,
        "step": 0.1
      },
      {
        "name": "overlay",
        "label": "Show Overlay",
        "type": "boolean",
        "default": true
      },
      {
        "name": "force",
        "label": "Force Re-process",
        "type": "boolean",
        "default": false
      },
      {
        "name": "id",
        "label": "Highlight ID",
        "type": "text",
        "description": "Process only this specific highlight"
      }
    ]
  },
  {
    "id": "postprocess-sound",
    "name": "Postprocess Sound",
    "description": "Apply background music to processed clips",
    "category": "Pipeline",
    "options": [
      {
        "name": "highlights",
        "label": "Highlights File",
        "type": "file",
        "filters": {
          "name": "JSON",
          "extensions": [
            "json"
          ]
        },
        "default": "./output/highlights.json"
      },
      {
        "name": "clips",
        "label": "Processed Clips Folder",
        "type": "folder",
        "default": "./output/clips_processed"
      },
      {
        "name": "output",
        "label": "Output Folder",
        "type": "folder",
        "default": "./output/clips_final"
      },
      {
        "name": "music",
        "label": "Music Folder",
        "type": "folder",
        "default": "./music"
      },
      {
        "name": "music-volume",
        "label": "Music Volume (%)",
        "type": "number",
        "default": 60,
        "min": 0,
        "max": 100
      },
      {
        "name": "force",
        "label": "Force Re-apply",
        "type": "boolean",
        "default": false
      },
      {
        "name": "id",
        "label": "Highlight ID",
        "type": "text",
        "description": "Apply music only to this specific highlight"
      }
    ]
  },
  {
    "id": "merge",
    "name": "Merge",
    "description": "Merge clips into a single video file",
    "category": "Pipeline",
    "options": [
      {
        "name": "clips",
        "label": "Clips Folder",
        "type": "folder",
        "required": true
      },
      {
        "name": "output",
        "label": "Output File",
        "type": "text",
        "default": "./output/highlights_final.mp4"
      },
      {
        "name": "transition",
        "label": "Transition Duration (s)",
        "type": "number",
        "default": 0.5,
        "min": 0,
        "max": 3,
        "step": 0.1
      },
      {
        "name": "cleanup",
        "label": "Delete Clips After Merge",
        "type": "boolean",
        "default": false
      }
    ]
  },
  {
    "id": "top",
    "name": "Top Highlights",
    "description": "Select top N highlights by impressiveness score",
    "category": "Utility",
    "options": [
      {
        "name": "highlights",
        "label": "Highlights File",
        "type": "file",
        "filters": {
          "name": "JSON",
