        "name": "show-scores",
        "label": "Show Score Breakdown",
        "type": "boolean",
        "default": false
      },
      {
        "name": "asc",
        "label": "Sort Ascending",
        "type": "boolean",
        "default": false,
        "description": "Sort by lowest score first (default: highest first)"
      },
      {
        "name": "player",
        "label": "Filter by Steam ID",
        "type": "text",
        "description": "Filter by player Steam ID"
      },
      {
        "name": "player-name",
        "label": "Filter by Nickname",
        "type": "text",
        "description": "Filter by player name (case-insensitive, partial match)"
      },
      {
        "name": "type",
        "label": "Filter by Type",
        "type": "select",
        "choices": [
          {
            "value": "",
            "label": "All"
          },
          {
            "value": "kill-series",
            "label": "Kill Series"
          },
          {
            "value": "clutch",
            "label": "Clutch"
          },
          {
            "value": "collateral",
            "label": "Collateral"
          },
          {
            "value": "knife",
            "label": "Knife"
          },
          {
            "value": "one-tap",
            "label": "One Tap"
          }
        ],
        "default": ""
      },
      {
        "name": "min-kills",
        "label": "Minimum Kills",
        "type": "number",
        "min": 1
      },
      {
        "name": "unique-players",
        "label": "Max per Player",
        "type": "number",
        "default": 1,
        "min": 1,
        "description": "Limit highlights per player for variety"
      }
    ]
  },
