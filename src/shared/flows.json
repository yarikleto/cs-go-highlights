[
  {
    "id": "full-legacy-pipeline",
    "name": "Full Legacy Pipeline",
    "description": "One-click highlight reel from a demo archive. Extracts demos, detects the top 20 highlights, records them with voice chat, adds speedup and overlays, merges into a single video, and compresses it. Just pick an archive and get a ready-to-share video.",
    "params": [
      {
        "name": "archive",
        "label": "Archive File",
        "type": "file",
        "filters": {
          "name": "Archive",
          "extensions": [
            "zip",
            "rar",
            "dem",
            "gz"
          ]
        },
        "required": true,
        "description": "Path to a .dem file, .dem.gz file, or zip/rar archive containing .dem files"
      },
      {
        "name": "outputPath",
        "label": "Output Video",
        "type": "save-file",
        "filters": {
          "name": "Video",
          "extensions": [
            "mp4"
          ]
        },
        "required": false,
        "description": "Where to save the final compressed video (defaults to ./output/highlights_final_compressed.mp4)"
      }
    ],
    "steps": [
      {
        "name": "Clean directories",
        "type": "clean-dirs",
        "dirs": [
          "./demos",
          "./output"
        ]
      },
      {
        "name": "Extract Demos",
        "command": "extract",
        "options": {
          "archive": "$archive",
          "output": "./demos"
        }
      },
      {
        "name": "Analyze (Legacy)",
        "command": "analyze",
        "options": {
          "demos": "./demos",
          "output": "./output"
        }
      },
      {
        "name": "Top Highlights",
        "command": "top",
        "options": {
          "highlights": "./output/highlights.json",
          "count": 20,
          "asc": true,
          "unique-players": 3,
          "output": "./output/highlights_top.json"
        }
      },
      {
        "name": "Record",
        "command": "record",
        "options": {
          "highlights": "./output/highlights_top.json",
          "voice-chat": true
        }
      },
      {
        "name": "Postprocess UI",
        "command": "postprocess-ui",
        "options": {
          "highlights": "./output/highlights_top.json",
          "speedup": 2,
          "overlay": true
        }
      },
      {
        "name": "Merge",
        "command": "merge",
        "options": {
          "clips": "./output/clips_processed"
        }
      },
      {
        "name": "Compress",
        "command": "compress",
        "options": {
          "input": "./output/highlights_final.mp4",
          "output": "$outputPath"
        }
      }
    ]
  },
  {
    "id": "player-highlights-pipeline",
    "name": "Player Highlights (Low → High)",
    "description": "Build a highlight reel for one specific player, sorted from worst to best. Pick a demo or archive and enter a nickname -- the tool finds all their highlights, ranks them, and records a progression-style video showing how the plays get more impressive.",
    "params": [
      {
        "name": "archive",
        "label": "Demo or Archive",
        "type": "file",
        "filters": {
          "name": "Demo / Archive",
          "extensions": [
            "dem",
            "gz",
            "zip",
            "rar"
          ]
        },
        "required": true,
        "description": "Path to a .dem file or a zip/rar archive containing .dem files"
      },
      {
        "name": "playerName",
        "label": "Player Nickname",
        "type": "text",
        "required": true,
        "description": "In-game nickname of the player to filter highlights for (partial match, case-insensitive)"
      },
      {
        "name": "topCount",
        "label": "Number of Highlights",
        "type": "number",
        "default": 10,
        "min": 1,
        "max": 100,
        "description": "How many top highlights to include in the video"
      },
      {
        "name": "outputPath",
        "label": "Output Video",
        "type": "save-file",
        "filters": {
          "name": "Video",
          "extensions": [
            "mp4"
          ]
        },
        "required": false,
        "description": "Where to save the final video (defaults to ./output/highlights_final.mp4)"
      }
    ],
    "steps": [
      {
        "name": "Clean directories",
        "type": "clean-dirs",
        "dirs": [
          "./demos",
          "./output"
        ]
      },
      {
        "name": "Extract Demos",
        "command": "extract",
        "options": {
          "archive": "$archive",
          "output": "./demos"
        }
      },
      {
        "name": "Analyze (Legacy)",
        "command": "analyze",
        "options": {
          "demos": "./demos",
          "output": "./output"
        }
      },
      {
        "name": "Top Highlights (Player, Low → High)",
        "command": "top",
        "options": {
          "highlights": "./output/highlights.json",
          "count": "$topCount",
          "asc": true,
          "player-name": "$playerName",
          "unique-players": 100,
          "output": "./output/highlights_top.json"
        }
      },
      {
        "name": "Record",
        "command": "record",
        "options": {
          "highlights": "./output/highlights_top.json",
          "voice-chat": true
        }
      },
      {
        "name": "Postprocess UI",
        "command": "postprocess-ui",
        "options": {
          "highlights": "./output/highlights_top.json",
          "speedup": 2,
          "overlay": true
        }
      },
      {
        "name": "Merge",
        "command": "merge",
        "options": {
          "clips": "./output/clips_processed",
          "output": "$outputPath"
        }
      }
    ]
  }
]
