[
  {
    "id": "full-legacy-pipeline",
    "name": "Full Legacy Pipeline",
    "description": "End-to-end pipeline that takes a demo archive and produces a compressed highlight video. Uses the legacy analyzer with point-based scoring, picks the top 20 highlights (ascending sort, max 3 per player), records with HUD/chat/voice enabled, applies visual postprocessing at 2x speedup with overlay, merges into a single video, and compresses the result. Ideal for quick one-click highlight reels from a batch of demos.",
    "params": [
      {
        "name": "archive",
        "label": "Archive File",
        "type": "file",
        "filters": {
          "name": "Archive",
          "extensions": [
            "zip",
            "rar"
          ]
        },
        "required": true,
        "description": "Path to zip/rar archive containing .dem files"
      },
      {
        "name": "outputPath",
        "label": "Output Video",
        "type": "save-file",
        "filters": {
          "name": "Video",
          "extensions": [
            "mp4"
          ]
        },
        "required": false,
        "description": "Where to save the final compressed video (defaults to ./output/highlights_final_compressed.mp4)"
      }
    ],
    "steps": [
      {
        "name": "Clean directories",
        "type": "clean-dirs",
        "dirs": [
          "./demos",
          "./output"
        ]
      },
      {
        "name": "Extract Demos",
        "command": "extract",
        "options": {
          "archive": "$archive",
          "output": "./demos"
        }
      },
      {
        "name": "Analyze (Legacy)",
        "command": "analyze",
        "options": {
          "demos": "./demos",
          "output": "./output"
        }
      },
      {
        "name": "Top Highlights",
        "command": "top",
        "options": {
          "highlights": "./output/highlights.json",
          "count": 20,
          "asc": true,
          "unique-players": 3,
          "output": "./output/highlights_top.json"
        }
      },
      {
        "name": "Record",
        "command": "record",
        "options": {
          "highlights": "./output/highlights_top.json",
          "voice-chat": true
        }
      },
      {
        "name": "Postprocess UI",
        "command": "postprocess-ui",
        "options": {
          "highlights": "./output/highlights_top.json",
          "speedup": 2,
          "overlay": true
        }
      },
      {
        "name": "Merge",
        "command": "merge",
        "options": {
          "clips": "./output/clips_processed"
        }
      },
      {
        "name": "Compress",
        "command": "compress",
        "options": {
          "input": "./output/highlights_final.mp4",
          "output": "$outputPath"
        }
      }
    ]
  },
  {
    "id": "player-highlights-pipeline",
    "name": "Player Highlights (Low → High)",
    "description": "Extract demos from an archive, analyze all highlights, filter by a specific player, sort from lowest to highest rating, and record everything. Produces individual clips sorted by impressiveness — great for a progression-style highlight reel.",
    "params": [
      {
        "name": "archive",
        "label": "Archive or Demos Folder",
        "type": "file",
        "filters": {
          "name": "Archive",
          "extensions": [
            "zip",
            "rar"
          ]
        },
        "required": true,
        "description": "Path to zip/rar archive containing .dem files"
      },
      {
        "name": "player",
        "label": "Player Steam ID",
        "type": "text",
        "required": true,
        "description": "64-bit Steam ID of the player to filter highlights for"
      },
      {
        "name": "outputPath",
        "label": "Output Video",
        "type": "save-file",
        "filters": {
          "name": "Video",
          "extensions": [
            "mp4"
          ]
        },
        "required": false,
        "description": "Where to save the final video (defaults to ./output/highlights_final.mp4)"
      }
    ],
    "steps": [
      {
        "name": "Clean directories",
        "type": "clean-dirs",
        "dirs": [
          "./demos",
          "./output"
        ]
      },
      {
        "name": "Extract Demos",
        "command": "extract",
        "options": {
          "archive": "$archive",
          "output": "./demos"
        }
      },
      {
        "name": "Analyze (Legacy)",
        "command": "analyze",
        "options": {
          "demos": "./demos",
          "output": "./output"
        }
      },
      {
        "name": "Top Highlights (Player, Low → High)",
        "command": "top",
        "options": {
          "highlights": "./output/highlights.json",
          "count": 100,
          "asc": true,
          "player": "$player",
          "unique-players": 100,
          "output": "./output/highlights_top.json"
        }
      },
      {
        "name": "Record",
        "command": "record",
        "options": {
          "highlights": "./output/highlights_top.json",
          "voice-chat": true
        }
      },
      {
        "name": "Postprocess UI",
        "command": "postprocess-ui",
        "options": {
          "highlights": "./output/highlights_top.json",
          "speedup": 2,
          "overlay": true
        }
      },
      {
        "name": "Merge",
        "command": "merge",
        "options": {
          "clips": "./output/clips_processed",
          "output": "$outputPath"
        }
      }
    ]
  }
]
